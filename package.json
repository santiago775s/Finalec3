{
  "name": "p-ec2-concurrent-downloader",
  "version": "1.0.0",
  "description": "Simulador de descargas concurrentes con DDD y Worker Threads",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "frontend:dev": "vite",
    "frontend:build": "vue-tsc -p tsconfig.frontend.json --noEmit && vite build",
    "frontend:preview": "vite preview",
    "test": "jest",
    "test:unit": "jest --selectProjects unit",
    "test:integration": "jest --selectProjects integration",
    "test:e2e": "jest --selectProjects e2e",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "dotenv": "^16.3.1",
    "express": "^4.22.2",
    "pinia": "^2.2.6",
    "primeicons": "^7.0.0",
    "primevue": "^3.53.1",
    "swagger-jsdoc": "^6.2.0",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^8.3.2",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.41",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-vue": "^5.2.1",
    "chart.js": "^4.4.7",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.11",
    "vue-tsc": "^2.1.10"
  }
}
